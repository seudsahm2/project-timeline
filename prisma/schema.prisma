generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  BOSS
}

model User {
  id               String            @id
  name             String
  email            String            @unique
  emailVerified    Boolean
  image            String?
  createdAt        DateTime
  updatedAt        DateTime
  sessions         Session[]
  accounts         Account[]
  profile          UserProfile?
  createdProjects  Project[]         @relation("ProjectCreator")
  projectMembers   ProjectMember[]
  dailyUpdates     DailyUpdate[]
  approvalComments ApprovalComment[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String            @id @default(cuid())
  name            String
  description     String?
  githubOwner     String?
  githubRepo      String?
  githubBranch    String?
  status          String            @default("On track")
  overallProgress Int               @default(0)
  selectedWeek    String            @default("Week 1")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdById     String
  createdBy       User              @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members         ProjectMember[]
  updates         DailyUpdate[]
  approvals       ApprovalComment[]
  activities      ActivityEvent[]

  @@index([createdById])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model DailyUpdate {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  status     String
  updateText String
  blockers   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([userId])
}

model ApprovalComment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([userId])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  projectId String
  source    String   @default("manual")
  message   String
  metadata  String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
